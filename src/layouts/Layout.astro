---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr-FR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700&family=Roboto+Slab:wght@100;300;400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/images/35v.png">
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Roboto', sans-serif;
    background-color: #000;
    color: #fff;
    overflow-x: hidden;
    line-height: 1.6;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Roboto Slab', serif;
    font-weight: 300;
  }

  h3 {
    font-size: 2rem;
    letter-spacing: 0.05em;
  }

  h4 {
    font-size: 1.6rem;
    letter-spacing: 0.05em;
  }

  h5 {
    font-size: 1rem;
    font-weight: 300;
    color: #aaa;
  }

  p {
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.8;
    color: #ccc;
  }

  .divider {
    width: 60px;
    height: 1px;
    background: #fff;
    margin: 20px 0;
  }

  /* Section base styles */
  section {
    width: 100%;
  }

  .section-boxed {
    max-width: 1140px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .section-full {
    width: 100%;
  }

  .flex-row {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .flex-row > * {
    flex: 1;
  }

  .col-text {
    padding: 60px 80px;
  }

  .col-image {
    overflow: hidden;
  }

  .col-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Gallery grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    padding: 30px 0;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 1 / 1.03;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item figcaption {
    position: absolute;
    bottom: 10px;
    left: 10px;
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255,255,255,0.7);
  }

  /* Three column layout */
  .three-col {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .three-col > * {
    flex: 1;
    padding: 40px;
  }

  /* Full width image */
  .full-image {
    width: 100%;
    overflow: hidden;
  }

  .full-image img {
    width: 100%;
    display: block;
  }

  /* Centered text section */
  .centered-text {
    text-align: center;
    padding: 80px 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Dark section with bg */
  .dark-section {
    background: #0a0a0a;
    padding: 80px 20px;
    text-align: center;
  }

  /* Slider section */
  .slider-section {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    position: relative;
    overflow: hidden;
    background: #111;
  }

  .slider-section .slide {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: slowZoom 20s ease-in-out infinite alternate;
  }

  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.05); }
  }

  /* Sketches section */
  .sketches-section {
    display: flex;
    align-items: center;
    min-height: 80vh;
    background: #0d0d0d;
  }

  .sketches-section .text-col {
    flex: 1;
    padding: 80px;
  }

  .sketches-section .image-col {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px;
  }

  .sketches-section .image-col img {
    max-height: 500px;
    width: auto;
  }

  /* Image boxes row */
  .image-boxes {
    display: flex;
    gap: 0;
  }

  .image-box {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .image-box:hover img {
    transform: scale(1.05);
  }

  .image-box .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
  }

  .image-box .overlay h3 {
    font-size: 1.3rem;
    margin-bottom: 5px;
  }

  .image-box .overlay p {
    font-size: 0.85rem;
    color: #aaa;
  }

  /* Footer */
  footer {
    text-align: center;
    padding: 40px 20px;
    background: #000;
  }

  footer img {
    width: 60px;
    margin: 0 auto;
    opacity: 0.5;
  }

  /* Hero section */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background: #000;
  }

  .hero .logo {
    width: 200px;
    height: 200px;
    animation: fadeInLogo 2s ease-out;
  }

  @keyframes fadeInLogo {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .scroll-arrow {
    text-align: center;
    padding: 20px;
    font-size: 2rem;
    color: #555;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(10px); }
  }

  /* V° text section */
  .v-section {
    display: flex;
    align-items: center;
    background: #0a0a0a;
    min-height: 60vh;
  }

  .v-section .text-col {
    flex: 1;
    padding: 80px;
  }

  .v-section .image-col {
    flex: 1;
  }

  .v-section .image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .flex-row,
    .three-col,
    .sketches-section,
    .image-boxes,
    .v-section {
      flex-direction: column;
    }

    .flex-row.reverse-mobile {
      flex-direction: column-reverse;
    }

    .col-text,
    .three-col > *,
    .sketches-section .text-col,
    .sketches-section .image-col,
    .v-section .text-col {
      padding: 40px 20px;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    h3 {
      font-size: 1.5rem;
    }

    .image-box {
      min-height: 250px;
    }
  }
</style>
